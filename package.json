{
  "name": "mac-slide-sci",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "build:pages": "tsc --noEmit && PUBLIC_BASE_PATH=/mac-slideSCI/ vite build && PUBLIC_BASE_URL=https://cherryamme.github.io/mac-slideSCI node scripts/build-manifest.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:manifest": "office-addin-manifest validate manifest.xml",
    "sideload:mac": "mkdir -p \"$HOME/Library/Containers/com.microsoft.Powerpoint/Data/Documents/wef\" && cp manifest.xml \"$HOME/Library/Containers/com.microsoft.Powerpoint/Data/Documents/wef/mac-slideSCI.xml\""
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.7.284",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "@types/office-js": "^1.0.517",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.5.0",
    "office-addin-manifest": "^2.1.5",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
